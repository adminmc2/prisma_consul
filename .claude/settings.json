{
  "permissions": {
    "allow": [
      "WebSearch",
      "mcp__claude_ai_Google_Drive__read_file_content",
      "mcp__claude_ai_Google_Drive__get_file_metadata",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(git push *)",
      "Bash(git fetch *)",
      "Bash(git mv *)",
      "Bash(git rm *)",
      "Bash(git log *)",
      "Bash(node -e ' *)",
      "Bash(npm install *)",
      "Bash(brew install *)",
      "Bash(psql --version)",
      "Bash(pg_dump --version)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/recordar-revisar-docs.sh\"",
            "if": "Bash(git commit*)",
            "timeout": 10,
            "statusMessage": "Comprobando deriva documental..."
          }
        ]
      }
    ]
  }
}